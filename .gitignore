node_modules/
client/node_modules/
# client/dist intentionally committed so EC2 needs no build step
# server/bundle.js intentionally committed — pre-bundled server (no npm install on EC2)
.env
*.log
.DS_Store

# Chat/agent attachments — not part of the app source
attached_assets/

# Terraform — never commit state (may contain secrets) or your tfvars
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example
terraform/crash.log
terraform/crash.*.log
terraform/override.tf
terraform/override.tf.json
