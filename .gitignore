client/node_modules/
# node_modules intentionally committed (server prod deps only, 4.9MB) so EC2 needs no npm install
# client/dist intentionally committed so EC2 needs no build step
.env
*.log
.DS_Store

# Chat/agent attachments — not part of the app source
attached_assets/

# Terraform — never commit state (may contain secrets) or your tfvars
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example
terraform/crash.log
terraform/crash.*.log
terraform/override.tf
terraform/override.tf.json
